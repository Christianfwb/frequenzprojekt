  "axioms": [
    {
      "id": "A0",
      "name": "Das Nullfeld",
      "formal": "N := {DeltaPhi = 0}",
      "text": "Praegeometrischer Zustand vor jeder Manifestation."
    },
    {
      "id": "A1",
      "name": "Frequenz ist primaer",
      "formal": "f [Hz] primaer",
      "text": "Frequenz ist die strukturierende Wiederholung selbst. Energie ist abgeleitet."
    },
    {
      "id": "A2",
      "name": "Information durch Unterscheidung",
      "formal": "I prop DeltaPhi",
      "text": "DeltaPhi=0 kein Sein. DeltaPhi!=0 Realitaet beginnt."
    },
    {
      "id": "A3",
      "name": "Zeit ist emergent",
      "formal": "T = DeltaPhi / f",
      "text": "Zeit emergiert aus Phasenfortschritt. T=1/f ist Spezialfall bei DeltaPhi=2pi."
    },
    {
      "id": "A4",
      "name": "Energie ist abgeleitet",
      "formal": "E = h * f",
      "text": "Energie ist messbare Wirkung der Frequenz."
    },
    {
      "id": "A5",
      "name": "Masse ist gebundene Frequenz",
      "formal": "m = h*f / c^2",
      "text": "Masse ist stabilisierter Frequenzzustand. Frequenz erzeugt Masse."
    },
    {
      "id": "A6",
      "name": "Frequenzerhaltung",
      "formal": "sum h*fi = const",
      "text": "Frequenz bleibt erhalten. Energieerhaltung folgt als Konsequenz."
    }
  ],
